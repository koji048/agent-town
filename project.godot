; Engine configuration file.
; Godot 4.x — Agent Town

config_version=5

[application]

config/name="Agent Town"
config/description="Ambient 16-bit isometric town of AI agents that produce Reels content. A Director agent cascades work to a crew of subagents powered by the Claude API."
run/main_scene="res://scenes/main.tscn"
config/features=PackedStringArray("4.3")
config/icon="res://assets/ui/icon.png"

[autoload]

Config="*res://scripts/autoload/config.gd"
EventBus="*res://scripts/autoload/event_bus.gd"
Claude="*res://scripts/autoload/claude_client.gd"
TaskQueue="*res://scripts/autoload/task_queue.gd"
OutputWriter="*res://scripts/autoload/output_writer.gd"
Sfx="*res://scripts/autoload/sfx.gd"
Juice="*res://scripts/autoload/juice.gd"
Memory="*res://scripts/autoload/memory.gd"
Chronicle="*res://scripts/autoload/chronicle.gd"
Storyteller="*res://scripts/autoload/storyteller.gd"
Transcriber="*res://scripts/autoload/transcriber.gd"
ReelRunner="*res://scripts/autoload/reel_runner.gd"
RoleLocks="*res://scripts/autoload/role_locks.gd"
I18n="*res://scripts/autoload/i18n.gd"
LeakMon="*res://scripts/autoload/leak_mon.gd"
PreviewMaker="*res://scripts/autoload/preview_maker.gd"

[gui]

theme/custom_font="res://assets/fonts/Anuphan.ttf"

[display]

window/size/viewport_width=1920
window/size/viewport_height=1080
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"

