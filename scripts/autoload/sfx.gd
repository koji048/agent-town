## Procedural foley playback (docs/CREATIVE_DIRECTION.md, pillar 3).
## Variants + pitch jitter (Unpacking's round-robin rule) so repetition
## never registers. All WAVs generated by tools/generate_assets.py.
extends Node

const VARIANTS := {
	"key": ["key_00", "key_01", "key_02", "key_03"],
	"step_wood": ["step_wood_00", "step_wood_01"],
	"step_hard": ["step_hard_00", "step_hard_01"],
	"step_soft": ["step_soft_00", "step_soft_01"],
	"paper": ["paper_00", "paper_01"],
	"chair": ["chair_00"],
	"chime": ["chime"],
	"chirp": ["chirp_00", "chirp_01", "chirp_02"],
}

var _streams: Dictionary = {}


func _ready() -> void:
	for group in VARIANTS:
		var list: Array = []
		for name in VARIANTS[group]:
			var path := "res://assets/audio/%s.wav" % name
			if ResourceLoader.exists(path):
				list.append(load(path))
		_streams[group] = list


## One-shot positional sound parented to `host` (auto-freed).
func play_at(host: Node, group: String, vol_db: float = 0.0, jitter: float = 0.08) -> void:
	var list: Array = _streams.get(group, [])
	if list.is_empty() or host == null or not host.is_inside_tree():
		return
	var p := AudioStreamPlayer3D.new()
	p.stream = list.pick_random()
	p.volume_db = vol_db
	p.pitch_scale = 1.0 + randf_range(-jitter, jitter)
	p.max_distance = 34.0
	p.unit_size = 6.0
	p.finished.connect(p.queue_free)
	host.add_child(p)
	p.play()


## One-shot global (non-positional) sound, e.g. the publish chime.
func play_ui(group: String, vol_db: float = 0.0) -> void:
	var list: Array = _streams.get(group, [])
	if list.is_empty():
		return
	var p := AudioStreamPlayer.new()
	p.stream = list.pick_random()
	p.volume_db = vol_db
	p.finished.connect(p.queue_free)
	add_child(p)
	p.play()


## The looping HVAC room-tone bed. Call once from main.
func start_room_tone(host: Node, vol_db: float = -24.0) -> void:
	var path := "res://assets/audio/roomtone.wav"
	if not ResourceLoader.exists(path):
		return
	var stream: AudioStreamWAV = load(path).duplicate()
	stream.loop_mode = AudioStreamWAV.LOOP_FORWARD
	stream.loop_begin = 0
	stream.loop_end = stream.data.size() / 2  # 16-bit mono: 2 bytes/frame
	var p := AudioStreamPlayer.new()
	p.stream = stream
	p.volume_db = vol_db
	host.add_child(p)
	p.play()
